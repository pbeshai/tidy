{
  "name": "tidy-packages",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "lerna run build --ignore \"@tidyjs/tidy-website\" --stream",
    "build:web": "yarn workspace @tidyjs/tidy-website build",
    "test": "lerna run test --stream",
    "test:build": "lerna run test:build --stream",
    "lint": "lerna run lint",
    "prettier": "lerna run prettier",
    "start:web": "yarn workspace @tidyjs/tidy-website start"
  },
  "devDependencies": {
    "@commitlint/cli": "^11.0.0",
    "@commitlint/config-conventional": "^11.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/d3-array": "^2.8.0",
    "@typescript-eslint/eslint-plugin": "^4.10.0",
    "@typescript-eslint/parser": "^4.10.0",
    "conventional-changelog-cli": "^2.1.1",
    "esbuild": "^0.27.4",
    "eslint": "^7.15.0",
    "eslint-config-prettier": "^7.0.0",
    "eslint-plugin-import": "^2.22.1",
    "expect-type": "^1.3.0",
    "husky": "^4.3.6",
    "vitest": "^3.1.1",
    "lerna": "^3.22.1",
    "lerna-changelog": "^1.0.1",
    "lint-staged": "^10.5.3",
    "moment": "^2.27.0",
    "prettier": "^2.2.1",
    "rimraf": "^3.0.2",
    "rollup": "^3.30.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^5.9.3"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "website"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        0
      ]
    }
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "packages/*/src/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pbeshai/tidy.git"
  }
}

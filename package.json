{
  "name": "tidy-packages",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "npm run build -w packages/tidy -w packages/tidy-moment",
    "build:web": "npm run build -w website",
    "test": "npm test --workspaces --if-present",
    "test:build": "npm run test:build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint --workspaces --if-present -- --fix",
    "prettier": "npm run prettier --workspaces --if-present",
    "start:web": "npm start -w website"
  },
  "devDependencies": {
    "@commitlint/cli": "^11.0.0",
    "@commitlint/config-conventional": "^11.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/d3-array": "^2.8.0",
    "conventional-changelog-cli": "^2.1.1",
    "esbuild": "^0.27.4",
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.0",
"typescript-eslint": "^8.57.0",
    "expect-type": "^1.3.0",
    "husky": "^4.3.6",
    "vitest": "^3.1.1",
    "lint-staged": "^10.5.3",
    "moment": "^2.27.0",
    "prettier": "^2.2.1",
    "rimraf": "^3.0.2",
    "rollup": "^3.30.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "packages/*",
    "website"
  ],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        0
      ]
    }
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "packages/*/src/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pbeshai/tidy.git"
  }
}
